{
    "name": "Caption Rater",
    "version": "1.2.0",
    "description": "Rate video captions",
    "manifest_version": 3,
    "permissions": ["storage", "tabs", "identity"],
    "host_permissions": [
      "https://*.youtube.com/*",
      "http://157.245.5.153/*",
      "http://localhost:5173/*"
    ],
    "background": {
      "service_worker": "background.js"
    },
    "content_scripts": [
      {
        "matches": ["https://*.youtube.com/*"],
        "js": ["popup.js", "contentScript.js"],
        "css": ["popup.css"]
      }
    ],
    "web_accessible_resources": [
      {
        "resources": [
          "assets/*"
        ],
        "matches": ["https://*.youtube.com/*"]
      }
    ]
}
